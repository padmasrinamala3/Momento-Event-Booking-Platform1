# ─────────────────────────────────────────────────
#  MomentO Backend — Environment Variables Template
#  Copy this file as `.env` and fill in the values.
#  ⚠️  NEVER commit the actual .env file to Git!
# ─────────────────────────────────────────────────

# Server port (AWS EB uses 8080 by default, override if needed)
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<db_user>:<db_password>@cluster0.beq18z3.mongodb.net/momento?retryWrites=true&w=majority&appName=Cluster0

# JWT secret key — use a long random string in production
JWT_SECRET=your_super_secret_key_here

# Gmail credentials for sending booking confirmation emails
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
